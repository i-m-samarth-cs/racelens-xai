# IBM Granite API Configuration
IBM_GRANITE_API_KEY=your_ibm_granite_api_key_here
IBM_GRANITE_API_URL=https://api.ibm.com/granite/v1
IBM_GRANITE_MODEL=granite-13b-instruct-v2

# Langflow Configuration
LANGFLOW_API_KEY=your_langflow_api_key_here
LANGFLOW_API_URL=https://api.langflow.org/v1
LANGFLOW_FLOW_ID=your_flow_id_here

# Docling Configuration
DOCLING_API_KEY=your_docling_api_key_here
DOCLING_API_URL=https://api.docling.com/v1

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
CORS_ORIGINS=http://localhost:3000,https://racelens-xai.vercel.app

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=RaceLens XAI
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database Configuration (Optional - defaults to SQLite)
DATABASE_URL=sqlite:///./racelens.db
# DATABASE_URL=postgresql://user:password@localhost:5432/racelens

# FastF1 Configuration
FASTF1_CACHE_DIR=./data/fastf1_cache
FASTF1_CACHE_ENABLED=true

# Data Storage
DATA_RAW_DIR=./data/raw
DATA_PROCESSED_DIR=./data/processed
DATA_DEMO_DIR=./data/demo

# Document Storage
DOCS_DIR=./data/documents
CHUNKS_DIR=./data/chunks
EMBEDDINGS_DIR=./data/embeddings

# Vector Database (Optional)
# PINECONE_API_KEY=your_pinecone_api_key
# PINECONE_ENVIRONMENT=your_pinecone_environment
# PINECONE_INDEX_NAME=racelens-docs

# Redis Cache (Optional)
# REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
ENABLE_LIVE_DATA=false
ENABLE_TELEMETRY=true
ENABLE_FAN_MODE=true
ENABLE_DOCUMENT_SEARCH=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Session Configuration
SESSION_SECRET=your_session_secret_here_change_in_production
SESSION_TIMEOUT=3600

# Analytics (Optional)
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# POSTHOG_API_KEY=your_posthog_key

# Monitoring (Optional)
# SENTRY_DSN=your_sentry_dsn
# SENTRY_ENVIRONMENT=development

# Demo Mode
DEMO_MODE=true
DEMO_DATA_REFRESH_INTERVAL=3600

# API Keys for External Services (Optional)
# OPENWEATHER_API_KEY=your_openweather_key
# MAPBOX_API_KEY=your_mapbox_key

# Security
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# Email (Optional - for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@racelens-xai.com

# Deployment
NODE_ENV=development
PYTHON_ENV=development